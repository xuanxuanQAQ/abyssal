    "@tiptap/extension-placeholder": "^2.0",
    "@tiptap/extension-subscript": "^2.0",
    "@tiptap/extension-superscript": "^2.0",
    "@tiptap/extension-table": "^2.0",
    "@tiptap/extension-table-cell": "^2.0",
    "@tiptap/extension-table-header": "^2.0",
    "@tiptap/extension-table-row": "^2.0",
    "@tiptap/react": "^2.0",
    "@tiptap/starter-kit": "^2.0",
    "better-sqlite3": "^11.0",
    "citeproc": "^2.0",
    "d3": "^7.0",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.0",
    "fast-xml-parser": "^5.5.9",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "https-proxy-agent": "^8.0.0",
    "i18next": "^26.0.2",
    "immer": "^10.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1",
    "jsonrepair": "^3.13.3",
    "katex": "^0.16.0",
    "lucide-react": "^0.460.0",
    "mupdf": "^1.27.0",
    "onnxruntime-node": "^1.24.3",
    "openai": "^4.70",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0",
    "react-arborist": "^3.4.0",
    "react-dom": "^19.0",
    "react-hot-toast": "^2.4",
    "react-i18next": "^17.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.0",
    "remark-directive": "^3.0.0",
