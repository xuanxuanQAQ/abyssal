{
  "name": "abyssal",
  "version": "0.1.0",
  "description": "AI-powered academic literature research pipeline",
  "main": "dist/electron/main.js",
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "dev": "npm run build:main && concurrently -n vite,tsc,esbuild,electron \"npm run dev:renderer\" \"npm run dev:tsc\" \"npm run dev:esbuild\" \"npm run dev:electron\"",
    "dev:renderer": "vite -c vite.renderer.config.ts",
    "dev:tsc": "tsc -p tsconfig.main.json --noEmit --watch --preserveWatchOutput",
    "dev:esbuild": "node esbuild.main.mjs --watch",
    "dev:electron": "electronmon . --dev",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json --noEmit && node esbuild.main.mjs",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "start": "electron .",
    "batch": "node dist/cli/batch.js",
    "package": "npm run build && electron-builder",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test:prepare": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:renderer": "vitest run --project renderer",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:prepare && vitest run",
    "electron:prepare": "npm rebuild better-sqlite3",
    "ci": "npm run typecheck && npm run lint && npm run test:prepare && vitest run",
    "test:mutate": "npx stryker run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@retorquere/bibtex-parser": "^7.0",
    "@tanstack/react-query": "^5.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-bubble-menu": "^2.0",
    "@tiptap/extension-highlight": "^2.0",
