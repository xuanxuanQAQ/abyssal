{
  "name": "abyssal",
  "version": "0.0.1",
  "description": "AI-powered academic literature research pipeline",
  "main": "dist/electron/main.js",
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "dev": "npm run build:main && concurrently -n vite,tsc,esbuild,electron \"npm run dev:renderer\" \"npm run dev:tsc\" \"npm run dev:esbuild\" \"npm run dev:electron\"",
    "dev:renderer": "vite -c vite.renderer.config.ts",
    "dev:tsc": "tsc -p tsconfig.main.json --noEmit --watch --preserveWatchOutput",
    "dev:esbuild": "node esbuild.main.mjs --watch",
    "dev:electron": "electronmon . --dev",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json --noEmit && node esbuild.main.mjs",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "start": "electron .",
    "batch": "node dist/cli/batch.js",
    "package": "npm run build && electron-builder",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test:prepare": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:renderer": "vitest run --project renderer",
    "test:smoke": "vitest run --project smoke",
    "test:golden": "vitest run --project golden",
    "test:robustness": "vitest run --project robustness",
    "test:evaluation": "vitest run --project evaluation",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:prepare && vitest run",
    "electron:prepare": "npm rebuild better-sqlite3",
    "ci": "npm run typecheck && npm run lint && npm run test:prepare && vitest run",
    "test:mutate": "npx stryker run"
  },
  "dependencies": {
